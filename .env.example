# ══════════════════════════════════════════════════════════════
# EuroRent AI — Переменные окружения
# Скопируй в .env и заполни значениями
# ══════════════════════════════════════════════════════════════

# === ОБЯЗАТЕЛЬНЫЕ ===

# Telegram Bot Token (от @BotFather)
TELEGRAM_TOKEN=your_telegram_token_here

# Groq API Key (console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Supabase (Settings → API в Dashboard)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# === TELEGRAM ===

# ID группы для постов (например -1001234567890)
GROUP_ID=

# ID канала для постов (если есть)
CHANNEL_ID=

# Город-специфичные каналы JSON: {"berlin": "-100xxx", "munich": "-100yyy"}
CITY_CHANNELS={}

# ID администратора (из @userinfobot)
ADMIN_ID=

# === TELETHON (для smart_poster) ===

# API ID и Hash (my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# === EMAIL (для newsletter) ===

# SMTP настройки
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NEWSLETTER_FROM=EuroRent AI <noreply@eurorent.ai>

# === DEPLOYMENT ===

# Порт для Flask healthcheck
PORT=10000

# Версия Python
PYTHON_VERSION=3.11
